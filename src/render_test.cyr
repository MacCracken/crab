# crab render_test — HOST harness: build two mock readdir buffers, render the
# dual-pane UI (kashi text), and dump the BGRA surface for a python→PNG eyeball.
# Fast layout iteration (no agnos / no real readdir).

include "src/ui.cyr"

# Write one 64-byte readdir record: name (NUL-terminated) at +0, type at +63.
fn rt_entry(buf, i, name, is_dir): i64 {
    var rec = buf + i * 64;
    var k = 0;
    while (load8(name + k) != 0) { store8(rec + k, load8(name + k)); k = k + 1; }
    store8(rec + k, 0);
    store8(rec + 63, is_dir);
    return 0;
}

fn main(): i64 {
    alloc_init();
    var lbuf = alloc(16 * 64); var rbuf = alloc(16 * 64);
    var a0 = "aethersafha"; rt_entry(lbuf, 0, a0, 0);
    var a1 = "puka";        rt_entry(lbuf, 1, a1, 0);
    var a2 = "crab";        rt_entry(lbuf, 2, a2, 0);
    var b0 = "bin";         rt_entry(rbuf, 0, b0, 1);
    var b1 = "boot";        rt_entry(rbuf, 1, b1, 1);
    var b2 = "readme.md";   rt_entry(rbuf, 2, b2, 0);
    var lp = "/bin"; var rp = "/";

    # mock sizes (parallel to the entries): files get a byte size, dirs get -1
    var lsizes = alloc(16 * 8); var rsizes = alloc(16 * 8);
    store64(lsizes + 0, 14995144); store64(lsizes + 8, 80784); store64(lsizes + 16, 301896);
    store64(rsizes + 0, 0 - 1);    store64(rsizes + 8, 0 - 1); store64(rsizes + 16, 4096);

    var w = 380; var h = 220;
    var sds = crab_render(w, h, 0, 0, 1, 0, lbuf, 3, lp, lsizes, rbuf, 3, rp, rsizes);   # left active, sel_l=1

    var pix = sd_surface_pixels(sds);
    var path = "/tmp/claude-1000/-home-macro-Repos-agnosticos/47a0fc83-d217-4059-a644-5fc638dfee33/scratchpad/crab.bin";
    var fd = syscall(2, path, 577, 420);
    if (fd >= 0) { syscall(1, fd, pix, w * h * 4); syscall(3, fd); }
    var ok = "crab render_test: dumped 380x220 BGRA\n"; syscall(1, 1, ok, strlen(ok));
    return 0;
}

fn _entry(): i64 { var r = main(); syscall(60, r); return 0; }
_entry();
